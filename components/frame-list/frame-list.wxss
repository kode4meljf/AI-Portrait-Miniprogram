.frame-scroll {
  width: 100%;
  white-space: nowrap;
}

.frame-list {
  display: inline-flex;
  gap: 24rpx;
  padding: 0 30rpx 30rpx;
}

.frame-item {
  display: inline-block;
  width: 280rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
  position: relative;
}

.frame-item.selected {
  border: 4rpx solid #07c160;
  transform: scale(0.98);
}

.frame-image {
  width: 280rpx;
  height: 280rpx;
  background: #f0f0f0;
}

.frame-info {
  padding: 20rpx;
}

.frame-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.frame-price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 600;
  margin-top: 8rpx;
  display: block;
}

.frame-detail {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 22rpx;
}