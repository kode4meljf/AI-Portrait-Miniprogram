<view class="grid">
  <view 
    class="grid-item"
    wx:for="{{imageList}}" 
    wx:key="index"
    bindtap="onImageTap"
    bindlongpress="onImageLongPress"
    data-index="{{index}}"
    data-url="{{item}}"
  >
    <image 
      class="grid-image" 
      src="{{item}}" 
      mode="aspectFill"
      lazy-load="{{true}}"
    ></image>
    <view 
      class="select-badge" 
      wx:if="{{showSelectBadge}}"
      bindtap="onSelectTap"
      data-index="{{index}}"
      data-url="{{item}}"
      catchtap="onSelectTap"
    >
      <text>{{selectBadgeText}}</text>
    </view>
  </view>
</view>