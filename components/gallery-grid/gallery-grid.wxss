.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.grid-item {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.grid-image {
  width: 100%;
  height: 100%;
}

.select-badge {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(7, 193, 96, 0.9);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  backdrop-filter: blur(4rpx);
}