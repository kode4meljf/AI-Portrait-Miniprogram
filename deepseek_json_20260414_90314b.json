{
  "pages": [
    "pages/index/index",
    "packageUser/pages/cloud-album/cloud-album",
    "packageUser/pages/order-list/order-list",
    "packageUser/pages/points/points"
  ],
  "subpackages": [
    {
      "root": "packageCore",
      "name": "core",
      "pages": [
        "pages/upload/upload",
        "pages/style/style",
        "pages/generate/generate",
        "pages/gallery/gallery",
        "pages/confirm/confirm",
        "pages/frame/frame"
      ]
    },
    {
      "root": "packageUser",
      "name": "user",
      "pages": [
        "pages/login/login"
      ]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["core"]
    }
  },
  "window": {
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "AI写真馆",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f5f5f5",
    "backgroundTextStyle": "dark"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#07c160",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "assets/images/tab-home.png",
        "selectedIconPath": "assets/images/tab-home-active.png"
      },
      {
        "pagePath": "packageUser/pages/cloud-album/cloud-album",
        "text": "云相册",
        "iconPath": "assets/images/tab-album.png",
        "selectedIconPath": "assets/images/tab-album-active.png"
      },
      {
        "pagePath": "packageUser/pages/order-list/order-list",
        "text": "订单",
        "iconPath": "assets/images/tab-order.png",
        "selectedIconPath": "assets/images/tab-order-active.png"
      },
      {
        "pagePath": "packageUser/pages/points/points",
        "text": "我的",
        "iconPath": "assets/images/tab-user.png",
        "selectedIconPath": "assets/images/tab-user-active.png"
      }
    ]
  },
  "lazyCodeLoading": "requiredComponents",
  "sitemapLocation": "sitemap.json"
}