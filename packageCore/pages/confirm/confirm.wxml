<view class="container">
  <!-- 大图展示区 -->
  <view class="image-preview">
    <image 
      class="main-image" 
      src="{{imageUrl}}" 
      mode="aspectFit"
      bindtap="onPreviewImage"
    ></image>
    <view class="re-select" bindtap="onReselect">
      <text>重新选择</text>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="info-tip">
    <text class="tip-text">确认后将为该照片制作实物相框</text>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button 
      class="confirm-btn" 
      bindtap="onConfirm"
      disabled="{{submitting}}"
    >
      {{submitting ? '确认中...' : '确认选图'}}
    </button>
    <view class="frame-entry" bindtap="onGoToFrame">
      <text>直接挑选相框款式 ></text>
    </view>
  </view>
</view>