<view class="container">
  <!-- 相框列表（横向滚动） -->
  <view class="frame-section">
    <view class="section-title">选择您喜欢的相框</view>
    <scroll-view 
      class="frame-scroll" 
      scroll-x="{{true}}" 
      show-scrollbar="{{false}}"
      enhanced="{{true}}"
    >
      <view class="frame-list">
        <view 
          class="frame-item {{selectedFrameId === item.id ? 'selected' : ''}}"
          wx:for="{{frameList}}" 
          wx:key="id"
          bindtap="onSelectFrame"
          data-id="{{item.id}}"
        >
          <image class="frame-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
          <view class="frame-info">
            <text class="frame-name">{{item.name}}</text>
            <text class="frame-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载相框中...</text>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button 
      class="notify-btn {{selectedFrameId ? 'active' : ''}}"
      bindtap="onNotifyEmployee"
      disabled="{{!selectedFrameId || submitting}}"
    >
      {{submitting ? '通知中...' : '通知员工下单'}}
    </button>
    <view class="points-tip" wx:if="{{selectedFrameId}}">
      <text>可使用积分抵扣部分金额</text>
    </view>
  </view>
</view>