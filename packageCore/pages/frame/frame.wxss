.container {
  background: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  padding: 30rpx;
}

.frame-scroll {
  width: 100%;
  white-space: nowrap;
}

.frame-list {
  display: inline-flex;
  gap: 24rpx;
  padding: 0 30rpx 30rpx;
}

.frame-item {
  display: inline-block;
  width: 280rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.frame-item.selected {
  border: 4rpx solid #07c160;
  transform: scale(0.98);
}

.frame-image {
  width: 280rpx;
  height: 280rpx;
  background: #f0f0f0;
}

.frame-info {
  padding: 20rpx;
}

.frame-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.frame-price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 600;
  margin-top: 8rpx;
  display: block;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.notify-btn {
  width: 100%;
  height: 96rpx;
  background: #cccccc;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  color: #ffffff;
}

.notify-btn.active {
  background: #07c160;
}

.points-tip {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999999;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}