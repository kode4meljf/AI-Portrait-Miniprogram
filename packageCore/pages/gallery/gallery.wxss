.container {
  background: #ffffff;
  min-height: 100vh;
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
  margin-top: 12rpx;
  display: block;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.grid-item {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.grid-image {
  width: 100%;
  height: 100%;
}

.select-badge {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(7, 193, 96, 0.9);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  backdrop-filter: blur(4rpx);
}

.skeleton-grid .skeleton-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
}

@keyframes loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.footer-tip {
  text-align: center;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
  color: #aaaaaa;
  font-size: 24rpx;
}