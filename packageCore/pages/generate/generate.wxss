.container { background: linear-gradient(180deg, #f0f7ff 0%, #ffffff 100%); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; }
.animation-area { width: 400rpx; margin-bottom: 80rpx; }
.skeleton-animation { position: relative; width: 300rpx; height: 300rpx; background: #e0e0e0; border-radius: 32rpx; margin: 0 auto; overflow: hidden; animation: pulse 1.5s ease-in-out infinite; }
.skeleton-body { position: absolute; bottom: 0; left: 0; right: 0; height: 180rpx; background: #d0d0d0; border-radius: 32rpx 32rpx 0 0; }
.skeleton-face { position: absolute; top: 60rpx; left: 50%; transform: translateX(-50%); width: 100rpx; height: 100rpx; background: #c0c0c0; border-radius: 50%; }
@keyframes pulse { 0%,100% { opacity: 0.6; } 50% { opacity: 1; } }
.progress-bar { width: 100%; height: 16rpx; background: #e0e0e0; border-radius: 8rpx; margin-top: 40rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #07c160; width: 0%; transition: width 0.3s ease; border-radius: 8rpx; }
.progress-text { text-align: center; margin-top: 20rpx; font-size: 32rpx; font-weight: 500; color: #07c160; }
.status-info { text-align: center; margin-top: 60rpx; }
.style-name { font-size: 36rpx; font-weight: 600; color: #333333; display: block; margin-bottom: 20rpx; }
.estimate-time { font-size: 28rpx; color: #666666; display: block; margin-bottom: 16rpx; }
.tip { font-size: 24rpx; color: #999999; }
.actions { display: flex; gap: 30rpx; margin-top: 100rpx; width: 100%; }
.cancel-btn, .refresh-btn { flex: 1; height: 80rpx; border-radius: 40rpx; font-size: 30rpx; display: flex; align-items: center; justify-content: center; }
.cancel-btn { background: #f5f5f5; color: #666666; }
.refresh-btn { background: #ffffff; border: 2rpx solid #07c160; color: #07c160; }
.error-tip { margin-top: 60rpx; color: #ff6b6b; font-size: 26rpx; }