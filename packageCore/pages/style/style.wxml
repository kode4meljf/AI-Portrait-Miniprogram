<view class="container">
  <view class="style-grid" wx:if="{{!loading && styleList.length > 0}}">
    <view class="style-item {{selectedStyleId === item.id ? 'selected' : ''}}" wx:for="{{styleList}}" wx:key="id" bindtap="onSelectStyle" data-id="{{item.id}}">
      <image class="style-image" src="{{item.previewUrl}}" mode="aspectFill" bindtap="onPreviewStyle" data-url="{{item.previewUrl}}" catchtap="onPreviewStyle"></image>
      <view class="style-info">
        <text class="style-name">{{item.name}}</text>
        <text class="style-desc">{{item.description}}</text>
      </view>
      <view class="check-icon" wx:if="{{selectedStyleId === item.id}}"><image src="/assets/images/check-circle.png"></image></view>
    </view>
  </view>
  <view class="loading-wrapper" wx:if="{{loading}}"><view class="loading-spinner"></view><text>加载风格中...</text></view>
  <view class="empty-state" wx:if="{{!loading && styleList.length === 0}}"><image src="/assets/images/empty-style.png"></image><text>暂无可用风格</text></view>
  <view class="bottom-bar" wx:if="{{styleList.length > 0}}">
    <button class="generate-btn {{selectedStyleId ? 'active' : ''}}" bindtap="onGenerate" disabled="{{!selectedStyleId || submitting}}">{{submitting ? '提交中...' : '生成写真'}}</button>
  </view>
</view>