.container {
  background: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.filter-bar {
  display: flex;
  background: #ffffff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.filter-item {
  margin-right: 40rpx;
  font-size: 30rpx;
  color: #666666;
  padding: 10rpx 0;
  position: relative;
}

.filter-item.active {
  color: #07c160;
  font-weight: 500;
}

.filter-item.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.album-list {
  padding: 20rpx 30rpx;
}

.album-item {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.album-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.album-date {
  font-size: 28rpx;
  color: #999999;
}

.album-actions {
  display: flex;
  gap: 30rpx;
}

.action {
  font-size: 26rpx;
  color: #07c160;
}

.album-images {
  padding: 30rpx;
}

.album-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999999;
}

.load-more, .no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #999999;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 20rpx;
}