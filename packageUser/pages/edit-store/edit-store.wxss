/* 编辑门店信息样式 */
.edit-store-page {
  min-height: 100vh;
  background: #fff;
}

/* 顶部导航 */
.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  padding-left: 16px;
  padding-right: 16px;
  padding-bottom: 12px;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-sizing: border-box;
}

.nav-back {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-save {
  font-size: 30rpx;
  color: #07c160;
  font-weight: 500;
}

.nav-save.disabled {
  color: #bbb;
}

/* 表单区域 */
.form-section {
  background: #fff;
  padding: 0 32rpx;
}

.form-group {
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-group:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  font-size: 32rpx;
  color: #333;
}

.form-textarea {
  width: 100%;
  font-size: 32rpx;
  color: #333;
  min-height: 120rpx;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 底部按钮 */
.bottom-action {
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: none;
  border-radius: 40rpx;
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 88rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
}

.btn-save:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-save.disabled {
  background: #f5f5f5;
  color: #bbb;
  box-shadow: none;
}
