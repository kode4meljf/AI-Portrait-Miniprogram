<view class="container">
  <view class="logo-area">
    <image class="logo" src="/assets/images/logo.png" mode="aspectFit"></image>
    <text class="app-name">AI写真馆</text>
  </view>
  <view class="form">
    <view class="input-group">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" maxlength="11" />
    </view>
  </view>
  <button class="login-btn" bindtap="onLogin" disabled="{{loginLoading}}">{{loginLoading ? '登录中...' : '一键登录'}}</button>
  <view class="agreement"><text>登录即代表同意《用户协议》和《隐私政策》</text></view>
</view>