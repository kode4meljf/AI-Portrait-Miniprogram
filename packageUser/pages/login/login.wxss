.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #ffffff 100%);
  padding: 120rpx 60rpx 60rpx;
  box-sizing: border-box;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
}

.form-area {
  margin-bottom: 40rpx;
}

.input-group {
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  font-size: 32rpx;
  color: #333333;
}

.code-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.code-btn {
  width: 200rpx;
  height: 60rpx;
  background: #07c160;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-btn[disabled] {
  background: #cccccc;
}

.privacy {
  display: flex;
  align-items: center;
  margin-bottom: 50rpx;
  font-size: 26rpx;
  color: #666666;
}

.privacy checkbox {
  transform: scale(0.8);
  margin-right: 10rpx;
}

.link {
  color: #07c160;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
}

.login-btn[disabled] {
  background: #cccccc;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}