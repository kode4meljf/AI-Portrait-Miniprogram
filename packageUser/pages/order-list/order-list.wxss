.container {
  background: #f8f8f8;
  min-height: 100vh;
  padding: 20rpx 30rpx 80rpx;
}

.order-item {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #666666;
}

.order-status {
  font-size: 28rpx;
  font-weight: 500;
}

.order-status.status-pending { color: #ff9800; }
.order-status.status-confirmed { color: #2196f3; }
.order-status.status-processing { color: #9c27b0; }
.order-status.status-shipped { color: #00bcd4; }
.order-status.status-arrived { color: #4caf50; }
.order-status.status-completed { color: #8bc34a; }
.order-status.status-cancelled { color: #f44336; }

.order-body {
  display: flex;
  padding: 30rpx;
  gap: 30rpx;
}

.order-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-style {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.order-frame {
  font-size: 26rpx;
  color: #666666;
}

.order-price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.order-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 24rpx;
  color: #999999;
}

.detail-btn {
  margin: 20rpx 30rpx 30rpx;
  width: calc(100% - 60rpx);
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  font-size: 28rpx;
  color: #666666;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}