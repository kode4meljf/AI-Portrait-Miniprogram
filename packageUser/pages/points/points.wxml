<view class="container">
  <!-- 积分卡片 -->
  <view class="points-card">
    <view class="points-amount">
      <text class="points-num">{{points}}</text>
      <text class="points-unit">积分</text>
    </view>
    <view class="points-tip">可抵扣相框费用</view>
  </view>

  <!-- 快捷入口 -->
  <view class="actions">
    <view class="action-item" bindtap="onGoToShare">
      <image src="/assets/images/icon-share.png"></image>
      <text>分享得积分</text>
    </view>
    <view class="action-item" bindtap="onViewRules">
      <image src="/assets/images/icon-rule.png"></image>
      <text>积分规则</text>
    </view>
  </view>

  <!-- 积分明细 -->
  <view class="record-section">
    <view class="section-title">积分明细</view>
    <view class="record-list" wx:if="{{records.length > 0}}">
      <view class="record-item" wx:for="{{records}}" wx:key="index">
        <view class="record-info">
          <text class="record-action">{{item.action}}</text>
          <text class="record-time">{{item.time}}</text>
        </view>
        <text class="record-points {{item.type === 'income' ? 'income' : 'expense'}}">
          {{item.type === 'income' ? '+' : ''}}{{item.points}}
        </text>
      </view>
    </view>
    <view class="empty-record" wx:if="{{!loading && records.length === 0}}">
      <text>暂无积分记录</text>
    </view>
  </view>
</view>