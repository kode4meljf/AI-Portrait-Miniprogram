.container {
  background: #f8f8f8;
  min-height: 100vh;
  padding: 30rpx;
}

.points-card {
  background: linear-gradient(135deg, #07c160 0%, #059c4e 100%);
  border-radius: 32rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.2);
}

.points-amount {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.points-num {
  font-size: 80rpx;
  font-weight: 700;
  color: #ffffff;
}

.points-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 10rpx;
}

.points-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.actions {
  display: flex;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.action-item {
  flex: 1;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-item image {
  width: 60rpx;
  height: 60rpx;
}

.action-item text {
  font-size: 28rpx;
  color: #333333;
}

.record-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-action {
  font-size: 30rpx;
  color: #333333;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
}

.record-points {
  font-size: 32rpx;
  font-weight: 500;
}

.record-points.income {
  color: #07c160;
}

.record-points.expense {
  color: #ff6b6b;
}

.empty-record {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}